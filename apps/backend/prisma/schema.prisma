// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         String   // 'client' | 'therapist' | 'admin'
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model StudentProfile {
  id           String   @id @default(uuid())
  studnetId    String   @unique
  acadamicYear String   @map("acadamic_year")

  student       User          @relation(fields: [id], references: [id]) 
  department    Department    @relation("Department")
}

model InstructorProfile {
  id            String        @id @default(uuid())
  instructorId  String        @unique

  instructor    User          @relation(fields: [id], references: [id])
  department    Department    @relation("Department")
}

model Department {
  id           String   @id @default(uuid())
  name         String
  code         String   @unique

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Course {
  id           String   @id @default(uuid())
  name         String   
  code         String   @unique
  acadamicYear String   @map("acadamic_year")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Resource {
  id           String   @id @default(uuid())
  title        String
  type         String   // PDF, PPT, DOCX...
  filePath     String   @map("file_path")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Summary {
  id           String   @id @default(uuid())
  content      String

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Quiz {
  id           String   @id @default(uuid())
  difficulty   String   // EASY, MEDIUM, HARD
  title        String

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Question {
  id           String   @id @default(uuid())
  content      String
  options      String
  correctAns   String   @map("correct_answer")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model QuizAttempt {
  id           String   @id @default(uuid())
  score        Number

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}

model Progress {
  id              String   @id @default(uuid())
  resourceViewed  Number
  averageScore    Number

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
}